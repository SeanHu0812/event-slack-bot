modules = ["python-3.12"]

# Used when you press "Run" in the editor (for quick testing only).
run = "python3 -u app.py"
entrypoint = "app.py"

# Deployment config. This bot is a long-running worker with no HTTP port,
# so it must be deployed as a Reserved VM (background worker), NOT Autoscale.
# When you create the deployment in the Replit UI, pick "Reserved VM" —
# that keeps this process (and its Slack websocket) up 24/7.
[deployment]
run = ["python3", "-u", "app.py"]
deploymentTarget = "gce"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
BUDGET_CSV_NYC = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQ82cDJbBKC7mXDEo4q0UMtyaNolNIWUnE-CQsM7ZbANNLhNPQasED_ykfyY5x7RorwYMkYljbxgkWn/pub?gid=227849508&single=true&output=csv"
