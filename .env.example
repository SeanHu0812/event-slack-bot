SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
NOTION_TOKEN=ntn_your-notion-integration-secret
ANTHROPIC_API_KEY=sk-ant-your-key
# Budget source (optional; without any of these, budget warnings are skipped).
# Preferred: a service-account key JSON on one line (or its base64).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Fallback: "Publish to web" CSV URLs, one per city tab. Used only when the
# service account above is not set.
BUDGET_CSV_NYC=https://docs.google.com/spreadsheets/d/e/.../pub?gid=...&single=true&output=csv
BUDGET_CSV_SF=https://docs.google.com/spreadsheets/d/e/.../pub?gid=...&single=true&output=csv
